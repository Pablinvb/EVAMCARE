# Entorno de ejecución: development, staging o production
DERMASCAN_ENV=development

# Dirección y puerto publicados por Docker Compose
DERMASCAN_HOST=0.0.0.0
DERMASCAN_PORT=8000

# Ruta persistente de SQLite dentro del contenedor
DERMASCAN_DATABASE_PATH=/app/data/dermascan.db

# Límites de carga y resolución
DERMASCAN_MAX_UPLOAD_MB=10
DERMASCAN_MAX_IMAGE_MEGAPIXELS=16

# Límite de análisis por sesión dentro de la ventana indicada
DERMASCAN_RATE_LIMIT_REQUESTS=20
DERMASCAN_RATE_LIMIT_WINDOW_SECONDS=600

# Orígenes permitidos, separados por comas
DERMASCAN_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
